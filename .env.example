# Convex — from `npx convex dev` or the Convex dashboard
CONVEX_DEPLOYMENT=
NEXT_PUBLIC_CONVEX_URL=

# Clerk — from https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Keep auth redirects same-origin (avoids failed RSC fetches on client navigations)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in

# Set on the Convex deployment (not in .env.local):
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://<your-app>.clerk.accounts.dev
# Create a "convex" JWT template in Clerk: https://docs.convex.dev/auth/clerk
